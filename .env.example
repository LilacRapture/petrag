# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=petrag

# Embeddings (runs inside the FastAPI container, CPU is fine for this model size)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# For Ollama running NATIVELY on Mac (Metal acceleration) - NOT in docker-compose.
# host.docker.internal lets the container reach services on the host machine.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Which project we're currently indexing + where its checkout is mounted read-only
SOURCE_PROJECT_NAME=tasktracker
SOURCE_PROJECT_PATH=/sources/tasktracker
